{
"manifest_version": 3,
"name": "YouTube Auto Skip",
"version": "1.1.0",
"description": "Automatically clicks YouTube skip buttons when they become available.",
"permissions": [
"debugger"
],
"background": {
"service_worker": "background.js"
},
"content_scripts": [
{
"matches": [
"https://www.youtube.com/*"
],
"js": [
"content.js"
],
"run_at": "document_idle"
}
]
}